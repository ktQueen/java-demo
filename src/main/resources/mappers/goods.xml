<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="goods">
    <select id="selectAll" resultType="com.imooc.jdbc.goods.Goods">
        select * from goods order by id desc limit 10
    </select>

    <select id="selectById" parameterType="Integer" resultType="com.imooc.jdbc.goods.Goods">
        select * from goods where id = #{value}
    </select>
</mapper>