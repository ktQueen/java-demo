<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE configuration
        PUBLIC "-//mybatis.org//DTD Config 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-config.dtd">
<mapper namespace="goods">
    <select id="selectAll" resultType="com.imooc.mybatis.emtity.Goods">
        select * fromt_goods order by goods_id desc limit 10
    </select>

    <select id="selectById" parameterType="Integer" resultType="com.imooc.mybatis.emtity.Goods">
        select * fromt_goods where goods_id=#{value}
    </select>
</mapper>